{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-payment" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-payment" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <div class="row mb-3">
            <label for="input-api-mode" class="col-sm-2 col-form-label">{{ entry_api_mode }}</label>
            <div class="col-sm-10">
              <select name="payment_ezonepay_api_mode" id="input-api-mode" class="form-select">
                <option value="dev"{% if payment_ezonepay_api_mode == 'dev' %} selected{% endif %}>{{ text_dev }}</option>
                <option value="production"{% if payment_ezonepay_api_mode == 'production' %} selected{% endif %}>{{ text_production }}</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-dev-api-key" class="col-sm-2 col-form-label">{{ entry_dev_api_key }}</label>
            <div class="col-sm-10">
              <input type="password" name="payment_ezonepay_dev_api_key" value="{{ payment_ezonepay_dev_api_key }}" placeholder="{{ entry_dev_api_key }}" id="input-dev-api-key" class="form-control"/>
              <div class="form-text">{{ help_dev_api_key }}</div>
              <div id="error-dev-api-key" class="invalid-feedback"></div>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-production-api-key" class="col-sm-2 col-form-label">{{ entry_production_api_key }}</label>
            <div class="col-sm-10">
              <input type="password" name="payment_ezonepay_production_api_key" value="{{ payment_ezonepay_production_api_key }}" placeholder="{{ entry_production_api_key }}" id="input-production-api-key" class="form-control"/>
              <div class="form-text">{{ help_production_api_key }}</div>
              <div id="error-production-api-key" class="invalid-feedback"></div>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-pending-status" class="col-sm-2 col-form-label">{{ entry_pending_status }}</label>
            <div class="col-sm-10">
              <select name="payment_ezonepay_pending_status_id" id="input-pending-status" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_ezonepay_pending_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-paid-status" class="col-sm-2 col-form-label">{{ entry_paid_status }}</label>
            <div class="col-sm-10">
              <select name="payment_ezonepay_paid_status_id" id="input-paid-status" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_ezonepay_paid_status_id %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-geo-zone" class="col-sm-2 col-form-label">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="payment_ezonepay_geo_zone_id" id="input-geo-zone" class="form-select">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                  <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == payment_ezonepay_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-debug" class="col-sm-2 col-form-label">{{ entry_debug }}</label>
            <div class="col-sm-10">
              <select name="payment_ezonepay_debug" id="input-debug" class="form-select">
                <option value="1"{% if payment_ezonepay_debug %} selected{% endif %}>{{ text_enabled }}</option>
                <option value="0"{% if not payment_ezonepay_debug %} selected{% endif %}>{{ text_disabled }}</option>
              </select>
              <div class="form-text">{{ help_debug }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-status" class="col-sm-2 col-form-label">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="payment_ezonepay_status" id="input-status" class="form-select">
                <option value="1"{% if payment_ezonepay_status %} selected{% endif %}>{{ text_enabled }}</option>
                <option value="0"{% if not payment_ezonepay_status %} selected{% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-sort-order" class="col-sm-2 col-form-label">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_ezonepay_sort_order" value="{{ payment_ezonepay_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control"/>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
